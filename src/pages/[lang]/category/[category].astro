---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';
import siteConfig from '../../../../site.config.mjs';
import { unsplashSrcset, unsplashAt } from '../../../lib/image';
import InfiniteReveal from '../../../components/InfiniteReveal.astro';
import { parseEntrySlug, t, localePrefix, ACTIVE_LOCALES, localeMeta } from '../../../lib/i18n';

// getStaticPaths s'exécute dans un contexte isolé → on déclare catToSlug à
// l'intérieur. On le ré-utilise aussi côté template via une const ci-dessous.
export async function getStaticPaths() {
  function catToSlug(cat: string): string {
    return (siteConfig.categorySlugs as Record<string, string>)?.[cat]
      ?? cat.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  }
  const CATS = siteConfig.categories as unknown as string[];
  const all = await getCollection('blog');
  const nonDefaultLocales = ACTIVE_LOCALES.filter(l => l !== siteConfig.i18n.defaultLocale);

  const paths = [];
  for (const lang of nonDefaultLocales) {
    const localePosts = all.filter(p => parseEntrySlug(p.slug).lang === lang);
    for (const cat of CATS) {
      paths.push({
        params: { lang, category: catToSlug(cat) },
        props: {
          cat,
          posts: localePosts
            .filter(p => p.data.category === cat)
            .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
        },
      });
    }
  }
  return paths;
}

const { lang } = Astro.params as { lang: 'fr' | 'en' | 'de' };
const { cat, posts } = Astro.props;
const lp = localePrefix(lang);
const url = (path: string) => `${lp}${path}`;
const articleHref = (slug: string) => url('/' + parseEntrySlug(slug).slug);

// Helper local pour le template (catToSlug est dans getStaticPaths)
function catToSlug(c: string): string {
  return (siteConfig.categorySlugs as Record<string, string>)?.[c]
    ?? c.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

const intlLocale = lang === 'en' ? 'en-GB' : lang === 'de' ? 'de-DE' : 'fr-FR';
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat(intlLocale, { year: 'numeric', month: 'long', day: 'numeric' }).format(date);

const SITE_URL = siteConfig.url;
const catSlug = catToSlug(cat);

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${cat} - ${siteConfig.name}`,
  description: `${cat} - ${posts.length}`,
  url: `${SITE_URL}${lp}/category/${catSlug}`,
  inLanguage: localeMeta(lang).htmlLang,
  isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: SITE_URL },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home', lang), item: `${SITE_URL}${lp}/` },
    { '@type': 'ListItem', position: 2, name: t('nav.blog', lang), item: `${SITE_URL}${lp}/blog` },
    { '@type': 'ListItem', position: 3, name: cat, item: `${SITE_URL}${lp}/category/${catSlug}` },
  ],
};

const blogCategories = siteConfig.categories as string[];
---

<BaseLayout
  title={`${cat} - ${siteConfig.name}`}
  description={`${cat}`}
  jsonLd={[collectionSchema, breadcrumbSchema]}
>
  <div class="max-w-7xl mx-auto px-6 pt-6 md:pt-8 pb-16 md:pb-24">
    <nav class="flex items-center gap-2 text-xs text-n-500 mb-6 font-light">
      <a href={url('/')} class="hover:text-cream transition-colors">{t('nav.home', lang)}</a>
      <span>/</span>
      <a href={url('/blog')} class="hover:text-cream transition-colors">{t('nav.blog', lang)}</a>
      <span>/</span>
      <span class="text-n-400">{cat}</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-cream leading-[1.1] mb-3">
        {cat}
      </h1>
      <p class="text-sm text-n-500 font-light">{posts.length}</p>
    </header>

    <!-- Category filters -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href={url('/blog')} class="text-xs font-medium px-4 py-2 rounded-full border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20 transition-colors">
        {t('blog.filterAll', lang)}
      </a>
      {blogCategories.map(c => {
        const isActive = c === cat;
        return (
          <a
            href={url(`/category/${catToSlug(c)}`)}
            class={`text-xs font-medium px-4 py-2 rounded-full transition-colors ${isActive ? 'bg-cream text-dark' : 'border border-white/[0.08] bg-white/[0.02] text-n-400 hover:text-cream hover:border-white/20'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {c}
          </a>
        );
      })}
    </div>

    {posts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-sm text-n-500 font-light">{t('blog.noPosts', lang)}</p>
      </div>
    ) : (
      <>
        <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {posts.map((post: any, i: number) => (
            <a href={articleHref(post.slug)} class="post-card group block">
              <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-panel border border-white/[0.05] mb-5">
                {post.data.image
                  ? <img
                      src={unsplashAt(post.data.image, 600)}
                      srcset={unsplashSrcset(post.data.image, [400, 600, 800])}
                      sizes="(max-width: 768px) calc(100vw - 48px), (max-width: 1024px) calc(50vw - 48px), 380px"
                      alt={post.data.imageAlt ?? post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500"
                      width="800" height="600"
                      loading={i === 0 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 ? 'high' : undefined}
                      decoding="async"
                    />
                  : <div class="w-full h-full flex items-center justify-center text-n-500"><Icon name="mouse" size={48} strokeWidth={1.25} /></div>
                }
              </div>
              <div>
                <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-2 block">{post.data.category}</span>
                <h2 class="text-base font-medium text-cream mb-1 tracking-tight leading-snug group-hover:underline underline-offset-4">
                  {post.data.title}
                </h2>
                <p class="text-xs text-n-500 font-light line-clamp-2 mt-1">{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()} class="text-[11px] text-n-500 font-light mt-3 block">{formatDate(post.data.pubDate)}</time>
              </div>
            </a>
          ))}
        </div>
        <InfiniteReveal targetId="posts-grid" itemSelector=".post-card" initial={9} batch={9} />
      </>
    )}
  </div>
</BaseLayout>
