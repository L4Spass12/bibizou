---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../../../../site.config.mjs';
import { unsplashSrcset } from '../../../lib/image';
import { inlineMd } from '../../../lib/inline-md';
import { parseEntrySlug, t, localePrefix, ACTIVE_LOCALES, localeMeta } from '../../../lib/i18n';
import InfiniteReveal from '../../../components/InfiniteReveal.astro';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  const allCategoryContent = await getCollection('productCategories');
  const cats: { slug: string; label: string }[] = siteConfig.productCategories || [];
  const nonDefaultLocales = ACTIVE_LOCALES.filter(l => l !== siteConfig.i18n.defaultLocale);

  const paths = [];
  for (const lang of nonDefaultLocales) {
    for (const cat of cats) {
      const content = allCategoryContent.find(e =>
        parseEntrySlug(e.slug).lang === lang && parseEntrySlug(e.slug).slug === cat.slug
      );
      paths.push({
        params: { lang, slug: cat.slug },
        props: {
          category: cat,
          content,
          products: allProducts
            .filter(p => parseEntrySlug(p.slug).lang === lang)
            .filter(p => (p.data.categories || []).includes(cat.slug))
            .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
        },
      });
    }
  }
  return paths;
}

const { lang } = Astro.params as { lang: 'fr' | 'en' | 'de' };
const { category, content, products } = Astro.props;
const lp = localePrefix(lang);
const url = (path: string) => `${lp}${path}`;
const productHref = (slug: string) => url('/product/' + parseEntrySlug(slug).slug);

const Content = content ? (await content.render()).Content : null;

const intlLocale = lang === 'en' ? 'en-GB' : lang === 'de' ? 'de-DE' : 'fr-FR';
const formatPrice = (n: number) => new Intl.NumberFormat(intlLocale, {
  style: 'currency', currency: localeMeta(lang).currency || 'EUR',
}).format(n);

const displayPrice = (d: any) =>
  d.priceRange && d.priceRange.min !== d.priceRange.max
    ? `${t('shop.from', lang)} ${formatPrice(d.priceRange.min)}`
    : formatPrice(d.price);

const SITE_URL = siteConfig.url;
const pageUrl = `${SITE_URL}${lp}/product-category/${category.slug}/`;

const pageTitle = content?.data.title
  ?? `${category.label} - ${siteConfig.name}`;
const pageDescription = content?.data.metaDescription
  ?? `${category.label}.`;
const intro = content?.data.intro ?? '';
const faq = content?.data.faq ?? [];
const keywords = content?.data.keywords ?? [];
const guideHeading = content?.data.guideHeading ?? category.label;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('nav.home', lang), item: `${SITE_URL}${lp}/` },
    { '@type': 'ListItem', position: 2, name: t('shop.breadcrumbShop', lang), item: `${SITE_URL}${lp}/${siteConfig.shop.path}` },
    { '@type': 'ListItem', position: 3, name: category.label, item: pageUrl },
  ],
};

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: pageUrl,
  inLanguage: localeMeta(lang).htmlLang,
  isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: SITE_URL },
  ...(keywords.length ? { keywords: keywords.join(', ') } : {}),
};

const itemListSchema = products.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: category.label,
  numberOfItems: products.length,
  itemListElement: products.slice(0, 30).map((p: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}${productHref(p.slug)}`,
    name: p.data.name,
  })),
} : null;

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item: any) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
} : null;

const jsonLd: any[] = [breadcrumbSchema, collectionSchema];
if (itemListSchema) jsonLd.push(itemListSchema);
if (faqSchema) jsonLd.push(faqSchema);
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <div class="max-w-7xl mx-auto px-6 pt-6 md:pt-8 pb-16 md:pb-20">
    <nav class="flex items-center gap-2 text-xs text-n-500 mb-4 font-light">
      <a href={url('/')} class="hover:text-cream transition-colors">{t('nav.home', lang)}</a>
      <span>/</span>
      <a href={url('/' + siteConfig.shop.path)} class="hover:text-cream transition-colors">{t('shop.breadcrumbShop', lang)}</a>
      <span>/</span>
      <span class="text-n-400">{category.label}</span>
    </nav>

    <header class="mb-10 max-w-3xl">
      <span class="text-[10px] text-n-500 font-medium uppercase tracking-widest mb-3 block">
        {products.length}
      </span>
      <h1 class="text-4xl md:text-5xl font-medium tracking-tight text-cream leading-[1.1] mb-6">
        {category.label}
      </h1>
      {intro && (
        <details class="intro-details">
          <summary>
            <p class="intro-text text-base md:text-lg text-n-400 font-light leading-relaxed">
              {intro}
            </p>
            <span class="intro-toggle">
              <span class="intro-toggle-more">{t('shop.readMore', lang)} ▾</span>
              <span class="intro-toggle-less">{t('shop.readLess', lang)} ▴</span>
            </span>
          </summary>
        </details>
      )}
    </header>

    <nav class="mb-12">
      <details class="cat-dropdown relative inline-block">
        <summary
          class="inline-flex items-center gap-3 px-5 py-3 rounded-full border border-white/[0.12] bg-white/[0.03] text-sm font-medium text-cream cursor-pointer hover:border-white/25 hover:bg-white/[0.06] transition-colors select-none"
        >
          <span class="text-n-500 text-xs uppercase tracking-widest">{t('shop.categoryLabel', lang)}</span>
          <span class="text-cream">{category.label.replace(new RegExp(`^${siteConfig.shop.categoryLabelPrefix ?? ''}\s*`, 'i'), '')}</span>
          <svg class="w-4 h-4 cat-chevron text-n-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <div class="cat-panel absolute top-full left-0 mt-2 min-w-[280px] md:min-w-[320px] rounded-2xl border border-white/[0.12] bg-panel shadow-2xl p-2 z-20" role="menu">
          <a href={url('/' + siteConfig.shop.path)} class="flex items-center justify-between gap-3 px-4 py-2.5 rounded-xl text-sm text-n-400 hover:bg-white/[0.05] hover:text-cream transition-colors">
            <span>{t('nav.categoriesAll', lang)}</span>
            <span class="text-[10px] text-n-500 uppercase tracking-widest">{t('nav.shop', lang)}</span>
          </a>
          <div class="h-px bg-white/[0.06] my-2 mx-2"></div>
          {(siteConfig.productCategories as {slug:string; label:string}[]).map(c => (
            <a
              href={url(`/product-category/${c.slug}`)}
              class={`flex items-center justify-between gap-3 px-4 py-2.5 rounded-xl text-sm transition-colors ${c.slug === category.slug ? 'bg-cream text-dark font-medium' : 'text-n-400 hover:bg-white/[0.05] hover:text-cream'}`}
              aria-current={c.slug === category.slug ? 'page' : undefined}
            >
              <span>{c.label.replace(new RegExp(`^${siteConfig.shop.categoryLabelPrefix ?? ''}\s*`, 'i'), '')}</span>
              {c.slug === category.slug && (
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              )}
            </a>
          ))}
        </div>
      </details>
    </nav>

    {products.length > 0 ? (
      <section>
        <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {products.map((product: any, i: number) => (
            <article class="product-card">
              <a href={productHref(product.slug)} class="group block">
                <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-panel border border-white/[0.05] mb-5">
                  <img
                    src={product.data.image}
                    srcset={unsplashSrcset(product.data.image)}
                    sizes="(max-width: 768px) calc(100vw - 48px), (max-width: 1024px) calc(50vw - 48px), 380px"
                    alt={product.data.imageAlt ?? product.data.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500"
                    width="800" height="600"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    fetchpriority={i === 0 ? 'high' : undefined}
                    decoding="async"
                  />
                  {product.data.compareAtPrice && (
                    <div class="absolute top-4 left-4">
                      <span class="bg-cream text-dark text-[10px] font-medium px-2 py-1 rounded-sm uppercase tracking-wider">{t('shop.sale', lang)}</span>
                    </div>
                  )}
                </div>
                <div class="flex justify-between items-start gap-4">
                  <div class="min-w-0">
                    <h2 class="text-base font-medium text-cream mb-1 tracking-tight group-hover:underline underline-offset-4 truncate">
                      {product.data.name}
                    </h2>
                    <p class="text-xs text-n-500 font-light truncate">{product.data.shortDescription}</p>
                  </div>
                  <div class="flex items-baseline gap-2 shrink-0">
                    <span class="text-sm text-cream font-medium whitespace-nowrap">{displayPrice(product.data)}</span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
        <InfiniteReveal targetId="products-grid" itemSelector=".product-card" initial={12} batch={12} />
      </section>
    ) : (
      <div class="text-center py-20">
        <p class="text-sm text-n-500 font-light">{t('shop.collectionEmpty', lang)}</p>
      </div>
    )}

    {Content && (
      <section class="mt-20 pt-12 border-t border-white/[0.08] max-w-3xl">
        <details class="group rounded-2xl border border-white/[0.08] bg-panel open:border-white/20 transition-colors">
          <summary class="flex items-start justify-between gap-4 px-6 py-5 cursor-pointer list-none font-medium text-base md:text-lg text-cream tracking-tight">
            <h2 class="flex-1 text-base md:text-lg font-medium tracking-tight">{guideHeading}</h2>
            <span class="text-n-400 text-xl leading-none transition-transform group-open:rotate-45 shrink-0">+</span>
          </summary>
          <article class="px-6 pb-6 pt-2 prose prose-invert max-w-none
            prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-cream prose-headings:scroll-mt-24
            prose-h3:text-lg prose-h3:mt-8 prose-h4:text-sm prose-h4:mt-5 prose-h4:uppercase prose-h4:tracking-wider prose-h4:text-n-400
            prose-p:font-light prose-p:text-n-400 prose-p:leading-relaxed prose-p:text-sm
            prose-a:text-cream prose-a:underline prose-a:underline-offset-4 prose-a:decoration-white/30 hover:prose-a:decoration-cream
            prose-strong:text-cream prose-strong:font-medium
            prose-ul:font-light prose-ol:font-light prose-li:text-n-400 prose-li:text-sm
            prose-hr:border-white/[0.08]">
            <Content />
          </article>
        </details>
      </section>
    )}

    {faq.length > 0 && (
      <section class="mt-20 pt-12 border-t border-white/[0.08] max-w-3xl">
        <h2 class="text-2xl md:text-3xl font-medium tracking-tight text-cream mb-8">{t('faq.title', lang)}</h2>
        <div class="space-y-3">
          {faq.map((f: any) => (
            <details class="group rounded-2xl border border-white/[0.08] bg-panel open:border-white/20 transition-colors">
              <summary class="flex items-start justify-between gap-4 px-6 py-5 cursor-pointer list-none font-medium text-base text-cream tracking-tight">
                <span class="flex-1" set:html={inlineMd(f.q)} />
                <span class="text-n-400 text-xl leading-none transition-transform group-open:rotate-45 shrink-0">+</span>
              </summary>
              <p class="px-6 pb-5 pt-1 font-light text-sm text-n-400 leading-relaxed [&_strong]:text-cream [&_strong]:font-medium [&_a]:text-cream [&_a]:underline [&_a]:underline-offset-4" set:html={inlineMd(f.a)} />
            </details>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .intro-details summary { list-style: none; cursor: pointer; }
  .intro-details summary::-webkit-details-marker { display: none; }
  .intro-details:not([open]) .intro-text {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Toggle "Read more / Show less" — uses real HTML spans (translated via
     t()) instead of CSS ::after content, so it stays localized. */
  .intro-toggle {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #F5F1E8;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(255, 255, 255, 0.3);
    transition: text-decoration-color 0.2s;
  }
  .intro-details summary:hover .intro-toggle { text-decoration-color: #F5F1E8; }
  .intro-details .intro-toggle-less { display: none; }
  .intro-details[open] .intro-toggle-more { display: none; }
  .intro-details[open] .intro-toggle-less { display: inline; }
  .cat-dropdown summary { list-style: none; }
  .cat-dropdown summary::-webkit-details-marker { display: none; }
  .cat-dropdown[open] .cat-chevron { transform: rotate(180deg); }
  .cat-chevron { transition: transform 0.2s ease; }
  .cat-panel { animation: cat-fade-in 0.15s ease-out; }
  @keyframes cat-fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
